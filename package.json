{
  "name": "@seed-design/icon",
  "version": "1.0.0",
  "repository": "https://github.com/Aniket-216/icon-generator.git",
  "author": "aniket-216 <aniketshinde216@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "svg",
    "drawable",
    "pdf",
    "lib"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js",
      "require": "./lib/*.cjs"
    }
  },
  "peerDependencies": {
    "react": "*"
  },
  "scripts": {
    "prepack": "bun run build",
    "generate:icona": "bun icona.js",
    "generate:react-index": "bun scripts/generate-react-index.cjs",
    "build": "bun run generate:react-index && bun run build:tsc && bun run build:js",
    "build:tsc": "tsc --emitDeclarationOnly",
    "build:js": "bun build.cjs",
    "release": "bun run changeset publish",
    "cs-version": "changeset version && bun install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@icona/generator": "^0.4.1",
    "@icona/types": "^0.4.1",
    "@icona/utils": "^0.4.1",
    "@svgr/plugin-jsx": "^8.0.1",
    "@svgr/plugin-prettier": "^8.0.1",
    "@svgr/plugin-svgo": "^8.0.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.24.2",
    "glob": "^11.1.0",
    "nanobundle": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svgo": "^3.3.2",
    "typescript": "^5.9.3"
  }
}